{
  "$schema": "https://raw.githubusercontent.com/nickkuk/nickkuk.github.io/refs/heads/master/tauri-v2.json",
  "productName": "LearnForge",
  "version": "0.1.0",
  "identifier": "com.learnforge.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LearnForge",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: <REPLACE_AFTER_ENROLLMENT> (<TEAM_ID>)",
      "entitlements": "./Entitlements.plist",
      "hardenedRuntime": true
    }
  }
}
